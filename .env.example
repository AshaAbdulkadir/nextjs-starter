# Copy this file to .env.local and paste your real connection string.
# .env.local is gitignored — secrets never get committed.
#
# Get the value from either:
#   - Vercel: Project -> Storage -> your Neon database -> ".env.local" tab
#   - Neon console: Project -> Connection Details -> Connection string
#
DATABASE_URL="postgresql://USER:PASSWORD@HOST/DBNAME?sslmode=require"
